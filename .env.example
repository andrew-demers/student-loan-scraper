# Nelnet credentials (Adam)
NELNET_USERNAME=your_nelnet_username
NELNET_PASSWORD=your_nelnet_password

# Optional: paste the My Loans URL from the browser after you open it manually once.
# MY_LOANS_URL=https://nelnet.studentaid.gov/loan-details

# Aidvantage credentials (Tracey)
TRACEY_USERNAME=traceys_fsa_username
TRACEY_PASSWORD=traceys_fsa_password
TRACEY_ACCOUNT_NUMBER=
# Date of birth in MM/DD/YYYY format
TRACEY_DOB=
# Sheet tab to write Tracey's data to (defaults to "Tracey")
TRACEY_SHEETS_TAB=Tracey

# Google Sheets (optional): service account JSON path; share the sheet with the SA email as Editor.
# See README for setup instructions.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id
GOOGLE_SHEETS_TAB=Data

# Gmail API for MFA email reading (works on corporate networks).
# Step 1: Create a Google Cloud project at https://console.cloud.google.com
# Step 2: Enable the Gmail API (APIs & Services > Library > Gmail API)
# Step 3: Create OAuth2 credentials (APIs & Services > Credentials > OAuth client ID > Desktop app)
#         Add http://localhost:3000 as an authorized redirect URI.
# Step 4: Fill in GMAIL_CLIENT_ID and GMAIL_CLIENT_SECRET below.
# Step 5: Run `npm run setup-gmail-auth` — it will open a browser, ask you to authorize,
#         and automatically save GMAIL_REFRESH_TOKEN to this file.
GMAIL_CLIENT_ID=your_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_client_secret
GMAIL_REFRESH_TOKEN=

# How long to wait for the MFA email (ms). Default 180000 (3 min).
MFA_IMAP_MAX_WAIT_MS=300000
# Set to 1 for verbose Gmail API debug logging.
MFA_IMAP_DEBUG=0
# Optional: substring of the sender address to filter on (default: nelnet).
MFA_EMAIL_FROM_CONTAINS=nelnetnoreply
# Optional: substring of the subject to filter on.
MFA_EMAIL_SUBJECT_CONTAINS=code

# Tracey's MFA email settings.
# If her MFA emails go to a different Gmail account, set separate OAuth creds below.
# Otherwise, the script reuses the GMAIL_* credentials above and filters by sender.
# TRACEY_GMAIL_CLIENT_ID=
# TRACEY_GMAIL_CLIENT_SECRET=
# TRACEY_GMAIL_REFRESH_TOKEN=
TRACEY_MFA_EMAIL_FROM_CONTAINS=aidvantage
# TRACEY_MFA_EMAIL_SUBJECT_CONTAINS=code
